---
interface Props {
  title: string;
  description: string;
  lang: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, lang, canonicalUrl, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const canonical = canonicalUrl || `${siteUrl}${currentPath}`;
const dir = lang === 'ar' ? 'rtl' : 'ltr';

const locales = ['en', 'es', 'zh', 'ru', 'pt', 'ar'];
const langNames: Record<string, string> = {
  en: 'English',
  es: 'Español',
  zh: '中文',
  ru: 'Русский',
  pt: 'Português',
  ar: 'العربية',
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="robots" content="index, follow" />

    <!-- Google Fonts - Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Hreflang -->
    {locales.map((loc) => {
      const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
      return <link rel="alternate" hreflang={loc} href={`${siteUrl}${path}`} />;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2701690512336282"
      crossorigin="anonymous"
    ></script>

    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: #e2e8f0;
        background: #080c12;
        min-height: 100vh;
      }
      a {
        color: #3b82f6;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
      }

      /* Header */
      header {
        background: rgba(8, 12, 18, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(59, 130, 246, 0.15);
        color: white;
        padding: 16px 0;
        position: sticky;
        top: 0;
        z-index: 100;
      }
      header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }
      .logo {
        font-size: 1.4rem;
        font-weight: 700;
        color: white;
        letter-spacing: -0.02em;
      }
      .logo:hover {
        text-decoration: none;
      }
      nav {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
      }
      nav a {
        color: #64748b;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.85rem;
        transition: all 0.2s;
      }
      nav a:hover,
      nav a.active {
        color: #93c5fd;
        background: rgba(59, 130, 246, 0.1);
        text-decoration: none;
      }

      /* Main */
      main {
        min-height: 70vh;
        padding: 0;
      }

      /* Hero */
      .hero {
        text-align: center;
        padding: 100px 20px 80px;
        background:
          radial-gradient(ellipse at 20% 50%, rgba(30, 64, 175, 0.3) 0%, transparent 60%),
          radial-gradient(ellipse at 80% 50%, rgba(59, 130, 246, 0.2) 0%, transparent 60%),
          radial-gradient(ellipse at 50% 100%, rgba(30, 64, 175, 0.15) 0%, transparent 50%),
          #080c12;
        color: white;
        margin-bottom: 0;
        position: relative;
        overflow: hidden;
        border-radius: 0;
      }
      .ml-hero-logo {
        border-radius: 50%;
        margin-bottom: 24px;
        background: rgba(255,255,255,.08);
        border: 2px solid rgba(59,130,246,.3);
        padding: 12px;
        filter: drop-shadow(0 8px 24px rgba(30,64,175,.4));
      }
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(59, 130, 246, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(59, 130, 246, 0.05) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
      }
      .hero h1 {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 8px;
        letter-spacing: -0.03em;
        position: relative;
      }
      .hero .gradient-text {
        display: block;
        font-size: 2.2rem;
        font-weight: 700;
        background: linear-gradient(135deg, #3b82f6, #93c5fd, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 16px;
      }
      .hero .lead {
        font-size: 1.15rem;
        opacity: 0.8;
        max-width: 640px;
        margin: 0 auto 32px;
        position: relative;
        line-height: 1.7;
      }
      .hero-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
        position: relative;
      }
      .hero-stat {
        text-align: center;
      }
      .hero-stat .stat-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #3b82f6;
      }
      .hero-stat .stat-label {
        font-size: 0.8rem;
        color: #64748b;
        margin-top: 2px;
      }

      /* Content area */
      .content-area {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 20px;
      }

      /* Cards */
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
        margin: 32px 0;
      }
      .card {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(59, 130, 246, 0.12);
        border-radius: 12px;
        padding: 28px;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
      }
      .card:hover {
        transform: translateY(-3px);
        border-color: rgba(59, 130, 246, 0.4);
        box-shadow: 0 12px 32px rgba(59, 130, 246, 0.1);
      }
      .card-icon {
        font-size: 2rem;
        margin-bottom: 12px;
        display: block;
      }
      .card h2 {
        font-size: 1.2rem;
        margin-bottom: 8px;
        color: #e2e8f0;
        font-weight: 600;
      }
      .card p {
        color: #94a3b8;
        font-size: 0.92rem;
        line-height: 1.6;
      }

      /* Ad slots */
      .ad-slot {
        background: rgba(15, 23, 42, 0.4);
        border: 1px dashed rgba(59, 130, 246, 0.15);
        padding: 20px;
        text-align: center;
        margin: 24px 0;
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #334155;
        font-size: 0.8rem;
        border-radius: 8px;
      }

      /* Registration */
      .registration-info {
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(59, 130, 246, 0.15);
        border-radius: 12px;
        padding: 32px;
        margin-top: 32px;
        text-align: center;
        backdrop-filter: blur(10px);
      }
      .registration-info h2 {
        margin-bottom: 16px;
        color: #93c5fd;
        font-size: 1.3rem;
      }
      .registration-info p {
        margin: 8px 0;
        color: #94a3b8;
        font-size: 0.92rem;
      }
      .registration-info strong {
        color: #cbd5e1;
      }

      /* Footer */
      footer {
        background: rgba(8, 12, 18, 0.9);
        border-top: 1px solid rgba(59, 130, 246, 0.1);
        color: #475569;
        padding: 24px 0;
        text-align: center;
        font-size: 0.85rem;
      }

      @media (max-width: 640px) {
        .hero {
          padding: 60px 20px 50px;
        }
        .hero h1 {
          font-size: 1.8rem;
        }
        .hero .gradient-text {
          font-size: 1.4rem;
        }
        .card-grid {
          grid-template-columns: 1fr;
        }
        .hero-stats {
          gap: 24px;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <a class="logo" href={`/${lang}/`}><slot name="logo">Site</slot></a>
        <nav>
          {locales.map((loc) => {
            const path = currentPath.replace(`/${lang}/`, `/${loc}/`);
            return (
              <a href={path} class={loc === lang ? 'active' : ''}>
                {langNames[loc]}
              </a>
            );
          })}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container">
        <p>&copy; {new Date().getFullYear()} <slot name="footer-name">Site</slot>. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
