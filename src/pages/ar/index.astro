---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarineQuiz from '../../components/MarineQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="Maryna Risk & Insurance | تغطية بحرية مهيكلة للسفن والعمليات البحرية"
  description="حلول تأمين B2B للسفن والتسجيلات البحرية وحماية الأصول الدولية. تغطية بحرية مهيكلة من Maryna Risk & Insurance."
  lang="ar"
>
  <Fragment slot="logo">Maryna Risk</Fragment>
  <Fragment slot="footer-name">Maryna Risk & Insurance – مسجلة في جمهورية كيريباتي</Fragment>

  <section class="hero">
    <h1>Maryna Risk & Insurance<span class="gradient-text">تغطية بحرية مهيكلة</span></h1>
    <p class="lead">حلول تأمين B2B للسفن والتسجيلات البحرية وحماية الأصول الدولية.</p>
    <div class="hero-stats">
      <div class="hero-stat"><div class="stat-value">B2B فقط</div><div class="stat-label">عملاء تجاريون</div></div>
      <div class="hero-stat"><div class="stat-value">تغطية عالمية</div><div class="stat-label">متعدد الولايات القضائية</div></div>
      <div class="hero-stat"><div class="stat-value">شبكة شركاء</div><div class="stat-label">نوادي P&I وشركات التأمين</div></div>
    </div>
  </section>

  <div class="content-area">
    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

    <MarineQuiz lang="ar" />

    <div class="card-grid">
      <article class="card">
        <span class="card-icon">🚢</span>
        <h2>تركيز بحري</h2>
        <p>تأمين للسفن التجارية والعمليات البحرية. تغطية السفن التجارية وقوارب العمل وسفن الخدمة وسفن الدعم البحري واليخوت المسجلة للاستخدام التجاري.</p>
      </article>
      <article class="card">
        <span class="card-icon">⚓</span>
        <h2>جاهز للبحر</h2>
        <p>دعم التسجيل البحري وهياكل التغطية المتوافقة. الهيكل والآلات والحماية والتعويض (P&I) عبر الشركاء وتغطية المخاطر التشغيلية.</p>
      </article>
      <article class="card">
        <span class="card-icon">🌊</span>
        <h2>نطاق دولي</h2>
        <p>تغطية للأصول والمعدات العاملة عبر الولايات القضائية. تأمين الأصول الصناعية والدولية للعمليات العابرة للحدود المعقدة.</p>
      </article>
      <article class="card">
        <span class="card-icon">🏢</span>
        <h2>B2B فقط</h2>
        <p>حلول مصممة حصرياً للشركات والمشغلين. هياكل قائمة على الشراكة بدون منتجات شخصية أو استهلاكية.</p>
      </article>
      <article class="card">
        <span class="card-icon">📋</span>
        <h2>الأصول المغطاة</h2>
        <p>السفن التجارية وقوارب العمل وسفن الخدمة وسفن الدعم البحري واليخوت المسجلة للاستخدام التجاري والمعدات الصناعية الدولية.</p>
      </article>
      <article class="card">
        <span class="card-icon">🛡️</span>
        <h2>إدارة المخاطر</h2>
        <p>تقييم شامل للمخاطر وتغطية مهيكلة مصممة للمخاطر المعقدة غير الشخصية في القطاعين البحري والصناعي.</p>
      </article>
    </div>

    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>

    <section class="registration-info">
      <h2>التسجيل والمعلومات القانونية</h2>
      <p><strong>رقم التسجيل:</strong> CP-000030</p>
      <p><strong>رقم الترخيص:</strong> KBN-80-000001</p>
      <p><strong>المكتب المسجل:</strong> Central Park, تاراوا, جمهورية كيريباتي</p>
      <p><strong>العنوان:</strong> ماليكون، مانزانيو، كوبا</p>
    </section>

    <WeeklyNews lang="ar" />

    <div class="ad-slot">مساحة إعلانية - Google AdSense</div>
  </div>
</BaseLayout>
