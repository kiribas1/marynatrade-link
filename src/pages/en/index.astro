---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarineQuiz from '../../components/MarineQuiz.astro';
import WeeklyNews from '../../components/WeeklyNews.astro';
---

<BaseLayout
  title="Maryna Risk & Insurance | Structured Marine Coverage for Vessels & Offshore"
  description="B2B insurance solutions for vessels, offshore registrations, and international asset protection. Structured marine coverage from Maryna Risk & Insurance."
  lang="en"
>
  <Fragment slot="logo">Maryna Risk</Fragment>
  <Fragment slot="footer-name">Maryna Risk & Insurance – Registered in the Republic of Kiribati</Fragment>

  <section class="hero">
    <h1>Maryna Risk & Insurance<span class="gradient-text">Structured Marine Coverage</span></h1>
    <p class="lead">B2B insurance solutions for vessels, offshore registrations, and international asset protection.</p>
    <div class="hero-stats">
      <div class="hero-stat"><div class="stat-value">B2B Only</div><div class="stat-label">Commercial Clients</div></div>
      <div class="hero-stat"><div class="stat-value">Global Coverage</div><div class="stat-label">Multi-Jurisdiction</div></div>
      <div class="hero-stat"><div class="stat-value">Partner Network</div><div class="stat-label">P&I Clubs & Insurers</div></div>
    </div>
  </section>

  <div class="content-area">
    <div class="ad-slot">Ad Space - Google AdSense</div>

    <MarineQuiz lang="en" />

    <div class="card-grid">
      <article class="card">
        <span class="card-icon">🚢</span>
        <h2>Marine-Focused</h2>
        <p>Insurance for commercial vessels and maritime operations. Covering commercial vessels, workboats, service boats, offshore support vessels, and registered yachts for business use.</p>
      </article>
      <article class="card">
        <span class="card-icon">⚓</span>
        <h2>Offshore-Ready</h2>
        <p>Support for offshore registration and compliant coverage structures. Hull & machinery, Protection & Indemnity (P&I) via partners, and operational risk coverage.</p>
      </article>
      <article class="card">
        <span class="card-icon">🌊</span>
        <h2>International Scope</h2>
        <p>Coverage for assets and equipment operating across jurisdictions. Industrial and international asset insurance for complex, cross-border operations.</p>
      </article>
      <article class="card">
        <span class="card-icon">🏢</span>
        <h2>B2B Only</h2>
        <p>Solutions designed exclusively for companies and operators. Partner-based structures with no personal or consumer products offered.</p>
      </article>
      <article class="card">
        <span class="card-icon">📋</span>
        <h2>Covered Assets</h2>
        <p>Commercial vessels, workboats, service boats, offshore support vessels, registered yachts for business use, and industrial equipment operating internationally.</p>
      </article>
      <article class="card">
        <span class="card-icon">🛡️</span>
        <h2>Risk Management</h2>
        <p>Comprehensive risk assessment and structured coverage designed for complex, non-personal risks in maritime and industrial sectors.</p>
      </article>
    </div>

    <div class="ad-slot">Ad Space - Google AdSense</div>

    <section class="registration-info">
      <h2>Registration & Legal</h2>
      <p><strong>Registration Number:</strong> CP-000030</p>
      <p><strong>License Number:</strong> KBN-80-000001</p>
      <p><strong>Registered Office:</strong> Central Park, Tarawa, Republic of Kiribati</p>
      <p><strong>Address:</strong> Malecon, Manzanillo, Cuba</p>
    </section>

    <WeeklyNews lang="en" />

    <div class="ad-slot">Ad Space - Google AdSense</div>
  </div>
</BaseLayout>
