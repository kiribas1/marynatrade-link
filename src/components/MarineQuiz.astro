function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const questions = shuffle(allQuestions).slice(0, 12);
let current = 0;
let score = 0;
let answered = false;

const qEl = document.getElementById('quiz-question');
const optEl = document.getElementById('quiz-options');
const fbEl = document.getElementById('quiz-feedback');
const nextBtn = document.getElementById('quiz-next');
const scoreEl = document.getElementById('quiz-score');
const bodyEl = document.getElementById('quiz-body');
const resultEl = document.getElementById('quiz-result');
const resultScore = document.getElementById('result-score');
const resultMsg = document.getElementById('result-msg');
const replayBtn = document.getElementById('quiz-replay');

function renderQuestion() {
  const q = questions[current];
  const currLang = lang || 'en';
  qEl.innerHTML = `<span class="q-num">${l.question} ${current + 1} ${l.of} 12</span><br>${q.q[currLang] || q.q.en}`;
  optEl.innerHTML = '';
  fbEl.innerHTML = '';
  fbEl.className = 'quiz-feedback';
  answered = false;
  nextBtn.style.display = 'none';

  const opts = q.options[currLang] || q.options.en;
  opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-option';
    btn.textContent = opt;
    btn.addEventListener('click', () => handleAnswer(i, q, currLang));
    optEl.appendChild(btn);
  });
}

function handleAnswer(idx, q, currLang) {
  if (answered) return;
  answered = true;
  const btns = optEl.querySelectorAll('.quiz-option');
  btns.forEach((btn, i) => {
    if (i === q.correct) btn.classList.add('correct');
    else if (i === idx) btn.classList.add('wrong');
    btn.disabled = true;
  });
  if (idx === q.correct) {
    score++;
    fbEl.innerHTML = `<div class="fb-correct">${l.correct}</div><div class="fb-fact"><strong>${l.funFact}:</strong> ${q.fact[currLang] || q.fact.en}</div>`;
    fbEl.className = 'quiz-feedback show-correct';
  } else {
    fbEl.innerHTML = `<div class="fb-wrong">${l.wrong}</div><div class="fb-fact"><strong>${l.funFact}:</strong> ${q.fact[currLang] || q.fact.en}</div>`;
    fbEl.className = 'quiz-feedback show-wrong';
  }
  scoreEl.textContent = `${l.score}: ${score} ${l.of} 12`;
  nextBtn.style.display = 'inline-block';
  nextBtn.textContent = current < 11 ? l.next : l.finish;
}

nextBtn.addEventListener('click', () => {
  current++;
  if (current >= 12) {
    bodyEl.style.display = 'none';
    resultEl.style.display = 'block';
    resultScore.textContent = `${score} ${l.of} 12`;
    if (score >= 10) resultMsg.textContent = l.great;
    else if (score >= 6) resultMsg.textContent = l.good;
    else resultMsg.textContent = l.tryAgain;
  } else {
    renderQuestion();
  }
});

replayBtn.addEventListener('click', () => { location.reload(); });

renderQuestion();
